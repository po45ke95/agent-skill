# ============================================================
# 範例設定檔 — 請複製為 .env 並填入實際值
# Example config — copy to .env and fill in real values
# ============================================================

# SonarQube
SONARQUBE_URL=http://your-sonarqube-host:9000
SONARQUBE_ADMIN_TOKEN=your_admin_token_here
SONARQUBE_PROJECT_KEY=MyProject
SONARQUBE_PROJECT_TOKEN=your_project_analysis_token_here

# (Optional) Email notification
MAIL_FROM=your.email@example.com
MAIL_TO=recipient@example.com
